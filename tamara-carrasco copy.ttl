@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org/mi-esquema#>. 
@prefix wd: <https://www.wikidata.org/entity/>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.

ex:Estudiante a rdfs:Class;
    rdfs:subClassOf foaf:Person.

ex:Institucion a rdfs:Class;

ex:estudiaEn a rdf:Property;
    rdfs:domain ex:Estudiante;
    rdfs:range ex:Institucion.

ex:tamara-carrasco a ex:Estudiante;
    foaf:name "Tamara Andrea Carrasco Agurto";
    foaf:nick "Juksay";
    foaf:birthday "1999-11-04"^^xsd:date;
    ex:EstudiaEn wd:Q232141;
    foaf:mbox <mailto:tamaracarrasco.agurto76@gmail.com>;
    foaf:img <https://example.com/avatar_juksay.png>;
    foaf:homepage <https://github.com/Tamaracarrasco>;
    foaf:knows ex:javiu;
    foaf:knows ex:daniel-hermosilla.

ex:estudiaEn rdfs:label "estudia en"@es.

ex:Estudiante rdfs:comment "Alguien que está matriculado en alguna institución de 
                            Educación superior"@es.
ex:Institucion rdfs:comment "Un lugar que forma a profesionales y académicos, reconocido por
                            el ministerio de educación"@es.

ex:javiu a foaf:Person;
    foaf:name "Javiera Yañez".

ex:daniel-hermosilla a foaf:Person;
    foaf:name "Daniel Hermosilla".


